# ─────────────────────────────────────────────────────────────
#  Autonomous Customer Acquisition Platform — Environment Config
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Platform Identity ──────────────────────────────────────────
# Name shown on the marketing homepage and super admin dashboard
PLATFORM_NAME=LaunchEngine

# Root domain — tenants served at [slug].PLATFORM_DOMAIN
PLATFORM_DOMAIN=yourplatform.com

# Full base URL for email links and OAuth redirects
BASE_URL=https://yourplatform.com

# ── Flask ──────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-very-long-random-string-in-production
FLASK_DEBUG=0

# ── Database ───────────────────────────────────────────────────
# SQLite (dev/testing only):
DATABASE_URL=sqlite:///platform.db
# PostgreSQL (required for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/growthengine

# ── Email — SendGrid (primary, recommended) ────────────────────
# https://app.sendgrid.com/settings/api_keys
# Free plan: 100 emails/day
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here

# ── Email — SMTP Fallback ──────────────────────────────────────
# Used if SENDGRID_API_KEY is blank or SendGrid fails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ── Stripe Platform ────────────────────────────────────────────
# Your platform Stripe keys (tenants connect THEIR accounts via Stripe Connect)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-platform-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-platform-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ── Stripe Connect ─────────────────────────────────────────────
# Enables tenants to connect their own Stripe accounts so payments
# are routed to them (minus the platform fee).
# Set up at: https://dashboard.stripe.com/settings/connect
# Recommended platform type: Express
STRIPE_CONNECT_CLIENT_ID=ca_your-connect-client-id

# ── Platform Revenue ───────────────────────────────────────────
# Default % of tenant revenue routed to your platform via Stripe Connect.
# Can be overridden per-tenant in the super admin panel.
PLATFORM_FEE_PCT=5.0

# ── Scheduler ──────────────────────────────────────────────────
# Email sequence check interval in seconds (default 900 = 15 min)
# The _auto_prospect job always runs at 6am UTC regardless of this setting.
SCHEDULER_INTERVAL=900
